# Screenshots
*.png
*.jpg
*.jpeg

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp

# User context pool (ignore contents, keep .gitkeep)
pool/**/*
!pool/**/.gitkeep

# External submodules (ignore contents, keep .gitkeep)
submodules/*
!submodules/.gitkeep
